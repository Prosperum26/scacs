PORT=3000
NODE_ENV=development

# MongoDB — local, Atlas, or Atlas Local (Docker)
MONGODB_URI=mongodb://127.0.0.1:27017/scacs

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY=7d
QR_TOKEN_EXPIRY_SEC=60

CORS_ORIGIN=http://localhost:5173

# Optional: gate name for scanner workstation
DEFAULT_GATE=Main Gate
