PORT=3000
NODE_ENV=development

# MongoDB Atlas (production) — see DEPLOY.md
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/scacs?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/scacs

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY=7d
QR_TOKEN_EXPIRY_SEC=60

# Local dev
CORS_ORIGIN=http://localhost:5173

# Production (Render) — exact Vercel URL, no trailing slash
# CORS_ORIGIN=https://your-app.vercel.app

# Multiple origins (comma-separated): production + preview
# CORS_ORIGIN=https://scacs.vercel.app,https://scacs-git-main-yourname.vercel.app

DEFAULT_GATE=Main Gate
